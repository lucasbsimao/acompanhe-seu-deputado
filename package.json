{
  "name": "AcompanheSeuDeputado",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "react-native start",
    "android": "npx react-native run-android",
    "ios": "cd ios && pod install && cd .. && react-native run-ios",
    "test": "jest",
    "test:all": "jest && npm test --prefix etl",
    "test:unit": "jest --testPathPattern='(?<!integration)\\.test\\.tsx?$'",
    "test:integration": "jest --testPathPattern='\\.integration\\.test\\.tsx?$'",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\""
  },
  "dependencies": {
    "@react-native/new-app-screen": "0.81.3",
    "@types/react-native": "^0.72.8",
    "react": "19.1.0",
    "react-native": "0.81.3",
    "react-native-safe-area-context": "^5.6.1",
    "react-native-sqlite-storage": "^6.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.81.3",
    "@react-native/eslint-config": "^0.81.3",
    "@react-native/metro-config": "0.81.3",
    "@react-native/typescript-config": "0.81.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.0.0",
    "@types/react": "^19.1.0",
    "@types/react-test-renderer": "^19.1.0",
    "better-sqlite3": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-sql": "^3.0.0",
    "eslint-plugin-react-native": "^5.0.0",
    "husky": "^9.1.7",
    "jest": "^29.6.3",
    "lint-staged": "^17.0.7",
    "prettier": "^3.2.0",
    "prettier-plugin-sql": "^0.18.0",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.60.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint --fix",
    "etl/**/*.ts": "etl/node_modules/.bin/eslint --fix",
    "**/*.{js,jsx,ts,tsx,json,md}": "prettier --write"
  },
  "engines": {
    "node": ">=20"
  }
}
