{
  "name": "api-data-retrieval",
  "version": "1.0.0",
  "description": "TypeScript-based ETL for retrieving Brazilian Congress deputy data",
  "license": "AGPL-3.0-or-later",
  "main": "dist/etl/src/main.js",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "start": "npm run build && node dist/etl/src/main.js",
    "dev": "ts-node src/main.ts",
    "test": "npm run clean && npm run build && node --test 'dist/etl/tests/**/*.test.js'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\""
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "axios": "^1.7.7",
    "axios-retry": "^4.5.0",
    "better-sqlite3": "^12.8.0",
    "csv-parse": "^5.5.3",
    "node-html-parser": "^7.0.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.9",
    "@types/prompts": "^2.4.9",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-sql": "^3.0.0",
    "typescript-eslint": "^8.0.0",
    "nock": "^13.5.0",
    "prettier": "^3.2.0",
    "prettier-plugin-sql": "^0.18.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
