{
  "name": "api-data-retrieval",
  "version": "1.0.0",
  "description": "TypeScript-based ETL for retrieving Brazilian Congress deputy data",
  "main": "dist/src/main.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/src/main.js",
    "dev": "ts-node src/main.ts",
    "test": "npm run build && node --test dist/tests/**/*.test.js"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "axios-retry": "^4.5.0",
    "better-sqlite3": "^12.8.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.9",
    "@types/prompts": "^2.4.9",
    "nock": "^13.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
